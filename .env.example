# ============================================================
# The5Agents — Environment variables (template)
# ------------------------------------------------------------
# Copy this file to ".env" and fill in your real values.
# Do NOT commit ".env" — it is ignored by git.
#   cp .env.example .env        (PowerShell: Copy-Item .env.example .env)
# ============================================================

# --- ראובן / הצוות: מודל Claude ---
# מפתח ה-API של Anthropic, משמש את כל הסוכנים (ראובן, יעל, יובל, חן)
ANTHROPIC_API_KEY=
# מזהה המודל שישמש כברירת מחדל
ANTHROPIC_MODEL=claude-opus-4-8

# --- חן (החוקרת): חיפוש ומחקר באינטרנט ---
# מפתח API לשירות חיפוש (לדוגמה Tavily / Brave / SerpAPI)
SEARCH_API_KEY=

# --- יובל (מעצב התמונות): יצירת תמונות ---
# מפתח API לשירות יצירת תמונות (גנרי — לדוגמה Stability / Replicate)
IMAGE_API_KEY=
# מפתח OpenAI ליצירת תמונות (מודל gpt-image-2), משמש את הסקיל gpt-image-gen
OPENAI_API_KEY=

# --- הגדרות כלליות ---
# סביבת ריצה: development | production
NODE_ENV=development
# רמת לוגים: debug | info | warn | error
LOG_LEVEL=info
